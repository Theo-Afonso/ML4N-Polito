    "\n",
    "def ecdf(ax, x, label=None, color=None):\n",
    "    \"\"\"Plot an ECDF on the given matplotlib axis.\"\"\"\n",
    "    x = np.sort(x)\n",
    "    y = np.arange(1, len(x) + 1) / len(x)\n",
    "    ax.step(x, y, where='post', label=label, color=color)\n",
    "\n"
   ]
